# API base URL (NestJS backend). Leave unset for in-browser tools only.
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# REQUIRED FOR PRODUCTION (snapptools.net)
# ═══════════════════════════════════════════════════════════════════
# Your live site URL. Used for sitemap, canonicals, Open Graph.
NEXT_PUBLIC_SITE_URL=https://snapptools.net

# Contact email shown on /contact. Create this inbox (e.g. in your domain host).
NEXT_PUBLIC_CONTACT_EMAIL=snapptools138@gmail.com

# ═══════════════════════════════════════════════════════════════════
# OPTIONAL – AdSense (add after approval)
# ═══════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_ID=xxxxxxxxxx
