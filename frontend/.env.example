# API base URL (NestJS backend). Used for QR generation when backend is running.
# Leave unset or set to empty to use in-browser fallback only.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Your live site URL (for sitemap and canonical). Set when deploying.
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Contact email shown on /contact (optional). Default: contact@yoursite.com
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com

# Google AdSense (optional). Get from google.com/adsense after approval.
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_ID=xxxxxxxxxx
